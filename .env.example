# Azure OpenAI Configuration
# ============================================
# This file contains the required environment variables.
# Copy this to .env and fill in your actual values.
#
# HOW TO GET YOUR API KEY:
# 1. Go to: https://prd-ifb220-apim.developer.azure-api.net/
# 2. Sign in with your QUT credentials
# 3. Go to "Profile / My Keys"
# 4. Copy your subscription key
#
# IMPORTANT: Do NOT share your API key or commit it to git!

# Your Azure API Key (from the developer portal)
AZURE_OPENAI_API_KEY=your_api_key_here

# Azure Endpoint (do NOT change this - it's QUT's specific endpoint)
AZURE_OPENAI_ENDPOINT=https://prd-ifb220-apim.azure-api.net/ifb220-ai